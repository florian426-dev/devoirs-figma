t** invent changes beyond what the diff describes."),e.hasAddedNode&&t.paragraph("**Added elements.** For new elements, use the **Reference** JSON as a guide for structure and props. Use existing components and patterns from the codebase where possible. **Asset images** may be attached\u2014one per image ref, keyed by the hash in **Image ref(s)**. For each image, **import** it (e.g. `import myImage from 'figma:asset/<hash>.png'`) and use the **imported variable** in `src={myImage}`. Do **not** put the `figma:asset/...` URL directly in `src=\"...\"`."),(e.hasAddedNode||e.hasRemovedNode)&&t.paragraph("**Preserve rendering patterns.** If elements in the target area are rendered from data (e.g. `.map()` over an array, loops), modify the data source or rendering logic rather than replacing it with hardcoded elements. When the diff shows multiple individual elements added or removed at the same source location, the intent is usually to change the underlying data or filter\u2014not to rewrite the rendering into static markup.")}(T,S,t),function(e,t,r,n){for(let N of d){let d=r.get(N);if(d?.length)for(let r of(t.h2(c[N]),d)){var o,s,u,p,E,C,j,T;let d=r[0];if(d)if(1===r.length)switch(N){case a.Y7.Color:o=e,s=t,u=d,p=n,u.targetKind!==a.$6.Prop?console.warn("Color change target kind is not prop",u):(s.h3(m(o,(0,l.rc)(u),u,p)),y(s,u));break;case a.Y7.Content:h(e,t,d,n);break;case a.Y7.Layout:g(e,t,d,n);break;case a.Y7.Typography:E=e,C=t,j=d,T=n,j.targetKind!==a.$6.Prop?console.warn("Typography change target kind is not prop",j):(C.h3(m(E,(0,l.b8)(j.propName),j,T)),y(C,j));break;default:!function(e,t,r,n){let i,l=b(r),o=k(r),s=w(r),u=e.changePrefix();if(r.op===a.vZ.Removed){let e=s??o;u+=`${l} removed${e?` (was \`${e}\`)`:""}`}else r.op===a.vZ.Modified&&void 0!==s&&void 0!==o?u+=`${l}: \`${s}\` \u{2192} \`${o}\``:r.op===a.vZ.Added&&void 0!==o?u+=`${l} set to \`${o}\``:r.op===a.vZ.Moved&&void 0!==r.oldPosition&&void 0!==r.newPosition?(u+=`${l} moved (position \`${r.oldPosition}\`